# ── Backend (server/index.js) ──────────────────────────────────────────
# Port the API listens on (default 3001)
PORT=3001

# On-chain credential minting (OPTIONAL — leave blank to run fully simulated).
# The issuer wallet pays gas so end users stay gasless. Fund it with a little
# Base Sepolia ETH, then deploy blockchain/ and paste the contract address.
ISSUER_PRIVATE_KEY=
CREDENTIAL_CONTRACT=
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── Frontend (Vite) ────────────────────────────────────────────────────
# Set this to your deployed contract so the Identity tab shows
# "BASE SEPOLIA" instead of "SIMULATED". Leave blank for demo mode.
VITE_CREDENTIAL_CONTRACT=
