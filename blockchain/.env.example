# ── Base Sepolia deployment ────────────────────────────────────────────
# Public RPC works out of the box; swap for Alchemy/Infura if you want.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Private key of the wallet that DEPLOYS the contract AND issues credentials.
# Fund it with a little Base Sepolia ETH first (free, see README).
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Optional: a different address allowed to mint (defaults to the deployer).
# ISSUER_ADDRESS=0x...
